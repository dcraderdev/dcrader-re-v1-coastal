    neighborhood: 'Del Mar',
    price: '$4.25M',
    soldDate: 'Feb 2025',
    image: 'https://images.unsplash.com/photo-1572120360610-d971b9d7767c?w=600&q=70&fm=webp&fit=crop&auto=format',
  },
  {
    address: '2209 Manchester Ave',
    neighborhood: 'Cardiff',
    price: '$1.68M',
    soldDate: 'Jan 2025',
    image: 'https://images.unsplash.com/photo-1505691938895-1758d7feb511?w=600&q=70&fm=webp&fit=crop&auto=format',
  },
  {
    address: '901 Hymettus Ave',
    neighborhood: 'Leucadia',
