  <!-- Floating "Call Sarah" pill -->
  <a
    id="floating-cta"
    href="tel:7605550192"
    class="fixed bottom-6 right-6 z-50 flex items-center gap-2 px-5 py-3 bg-sage text-cream font-sans text-xs font-medium uppercase tracking-widest rounded-full opacity-0 translate-y-4 transition-all duration-300 hover:bg-sage-dark"
    style="box-shadow: 0 8px 30px rgba(107,143,107,0.4);"
    aria-label="Call Sarah Mitchell"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 7V5z"/>
    </svg>
