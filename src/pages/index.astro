const credentials = [
  'Compass Top Producer — North County Coastal, 2019–2025',
  'San Diego Association of Realtors — Platinum Member',
  'Certified Luxury Home Marketing Specialist (CLHMS)',
  'Encinitas Coastal Conservancy — Board Member',
  'UC San Diego — BA, Communications',
];

const footerLinks = ['Properties', 'Neighborhoods', 'About Sarah', 'Contact', 'Home Valuation'];

const valueProps = [
  'Complimentary home valuation within 24 hours',
  'No pressure, no obligation — just honest insight',
  'Direct line to Sarah, not a call center',
  'Compass Concierge program to maximize value',
];
---

<Layout>
  <!-- ===== NAV ===== -->
  <nav id="nav" class="fixed top-0 left-0 right-0 z-50 bg-cream/90 backdrop-blur-md border-b border-sand/20 transition-all duration-300">
    <div class="max-w-screen-xl mx-auto px-6 lg:px-10 h-16 flex items-center justify-between">
      <a href="/" class="flex flex-col leading-none">
        <span class="font-serif text-xl font-black italic text-charcoal tracking-tight">Sarah Mitchell</span>
        <span class="text-[10px] font-sans font-medium uppercase tracking-[0.25em] text-sage mt-0.5">Encinitas</span>
      </a>
      <div class="hidden lg:flex items-center gap-8">
        <a href="#listings" class="text-[11px] font-sans font-medium uppercase tracking-widest text-charcoal/70 hover:text-sage transition-colors">Properties</a>
        <a href="#lifestyle" class="text-[11px] font-sans font-medium uppercase tracking-widest text-charcoal/70 hover:text-sage transition-colors">Neighborhoods</a>
        <a href="#bio" class="text-[11px] font-sans font-medium uppercase tracking-widest text-charcoal/70 hover:text-sage transition-colors">About</a>
        <a href="#contact" class="text-[11px] font-sans font-medium uppercase tracking-widest text-charcoal/70 hover:text-sage transition-colors">Contact</a>
        <a href="tel:7605550192" class="ml-2 px-5 py-2 rounded-full border border-sage text-sage text-[11px] font-sans font-medium uppercase tracking-widest hover:bg-sage hover:text-cream transition-all duration-200">
          Call (760) 555-0192
        </a>
      </div>
      <button id="hamburger" class="lg:hidden flex flex-col gap-1.5 p-2 z-50 relative" aria-label="Open menu">
        <span class="w-6 h-0.5 bg-charcoal transition-all duration-300 origin-center" id="ham-1"></span>
        <span class="w-6 h-0.5 bg-charcoal transition-all duration-300" id="ham-2"></span>
        <span class="w-4 h-0.5 bg-charcoal transition-all duration-300 origin-center" id="ham-3"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="fixed inset-0 z-40 bg-cream flex flex-col items-center justify-center gap-8 translate-x-full transition-transform duration-300 ease-in-out">
    <a href="#listings" class="mobile-nav-link font-serif text-4xl italic text-charcoal hover:text-sage transition-colors">Properties</a>
    <a href="#lifestyle" class="mobile-nav-link font-serif text-4xl italic text-charcoal hover:text-sage transition-colors">Neighborhoods</a>
    <a href="#bio" class="mobile-nav-link font-serif text-4xl italic text-charcoal hover:text-sage transition-colors">About</a>
    <a href="#contact" class="mobile-nav-link font-serif text-4xl italic text-charcoal hover:text-sage transition-colors">Contact</a>
    <a href="tel:7605550192" class="mt-4 px-8 py-3 rounded-full bg-sage text-cream font-sans text-sm font-medium uppercase tracking-widest hover:bg-sage-dark transition-colors">
      (760) 555-0192
    </a>
  </div>

  <main>
    <!-- ===== HERO: ASYMMETRIC SPLIT ===== -->
    <section id="hero" class="min-h-screen flex flex-col lg:flex-row">
      <!-- Left: Sage panel -->
      <div class="bg-sage flex flex-col justify-between px-8 lg:px-16 pt-28 pb-10 lg:w-[45%] min-h-[65vh] lg:min-h-screen order-2 lg:order-1">
        <div>
          <p class="text-[10px] font-sans font-medium uppercase tracking-[0.35em] text-cream/60 mb-10">Compass · Encinitas</p>
          <h1 class="font-serif font-black text-cream leading-[0.88] tracking-tight mb-6" style="font-size: clamp(4rem, 7.5vw, 7.5rem);">
            Sarah<br />Mitchell
          </h1>
          <p class="font-serif italic text-cream/80 mb-10 leading-snug" style="font-size: clamp(1.25rem, 2.5vw, 1.75rem);">
            Your home story<br />starts here.
          </p>
          <a href="#listings" class="inline-block px-7 py-3.5 border-2 border-cream text-cream font-sans text-xs font-medium uppercase tracking-widest hover:bg-cream hover:text-sage transition-all duration-200 rounded-sm">
            Explore Properties &rarr;
          </a>
          <br />
          <a href="tel:7605550192" class="mt-5 inline-block text-cream/55 font-sans text-sm hover:text-cream transition-colors underline underline-offset-4">
            Or call (760) 555-0192
          </a>
        </div>
        <!-- Stats strip -->
        <div class="border-t border-cream/20 pt-8 mt-12 grid grid-cols-2 xl:grid-cols-4 gap-y-6 gap-x-4">
          <div>
            <p class="font-serif font-black text-cream text-2xl leading-none">340+</p>
            <p class="text-cream/55 font-sans text-[10px] uppercase tracking-widest mt-1.5">Homes Sold</p>
          </div>
          <div>
            <p class="font-serif font-black text-cream text-2xl leading-none">11</p>
            <p class="text-cream/55 font-sans text-[10px] uppercase tracking-widest mt-1.5">Years</p>
          </div>
          <div>
            <p class="font-serif font-black text-cream text-2xl leading-none">$680M</p>
            <p class="text-cream/55 font-sans text-[10px] uppercase tracking-widest mt-1.5">Volume</p>
          </div>
          <div>
            <p class="font-serif font-black text-cream text-2xl leading-none">9</p>
            <p class="text-cream/55 font-sans text-[10px] uppercase tracking-widest mt-1.5">Days avg</p>
          </div>
        </div>
      </div>
      <!-- Right: Hero image -->
      <div class="relative lg:w-[55%] min-h-[55vw] lg:min-h-screen overflow-hidden order-1 lg:order-2">
        <img
          src="/hero-md.webp"
          srcset="/hero-sm.webp 640w, /hero-md.webp 850w, /hero.webp 1100w"
          sizes="(max-width: 640px) 100vw, (max-width: 1024px) 100vw, 55vw"
          alt="Luxury coastal home in Encinitas"
          class="absolute inset-0 w-full h-full object-cover"
          fetchpriority="high"
          decoding="sync"
          loading="eager"
        />
        <div class="absolute inset-y-0 left-0 w-20 bg-gradient-to-r from-sage to-transparent pointer-events-none hidden lg:block"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-charcoal/25 via-transparent to-transparent pointer-events-none"></div>
      </div>
    </section>

    <!-- ===== CHAPTER ONE: LISTINGS ===== -->
    <section id="listings" class="py-24 lg:py-36 px-6 lg:px-16 max-w-screen-2xl mx-auto">
      <div class="mb-16 fade-in">
        <p class="text-[10px] font-sans font-medium uppercase tracking-[0.35em] text-sage mb-3">Chapter One</p>
        <h2 class="font-serif font-black text-charcoal leading-tight" style="font-size: clamp(2.5rem, 5vw, 4.5rem);">Your Perfect Home</h2>
        <p class="mt-4 font-sans text-charcoal/55 max-w-lg leading-relaxed" style="font-size: 1.05rem;">
          Carefully curated coastal properties along San Diego's most coveted shoreline communities.
        </p>
      </div>

      <!-- Asymmetric grid — Row 1: 5 + 7 -->
      <div class="grid grid-cols-12 gap-6 lg:gap-8">
        <!-- Card 1: col-span-5 -->
        <div class="col-span-12 md:col-span-5 fade-in" style="transform: rotate(-1.2deg);">
          <article class="listing-card bg-white overflow-hidden group cursor-pointer" style="box-shadow: 0 20px 60px rgba(0,0,0,0.15);">
            <div class="overflow-hidden" style="aspect-ratio: 4/3;">
              <img src={listings[0].image} alt={listings[0].address} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <p class="font-sans text-[10px] uppercase tracking-[0.2em] text-sage font-medium mb-1">{listings[0].neighborhood}</p>
                  <h3 class="font-serif font-bold text-charcoal text-xl">{listings[0].address}</h3>
                </div>
                <span class="px-3 py-1 bg-sage/10 text-sage text-[10px] font-sans font-medium uppercase tracking-widest rounded-full shrink-0 ml-3">{listings[0].status}</span>
              </div>
              <p class="font-serif font-black text-charcoal text-2xl mb-4">{listings[0].price}</p>
              <div class="flex gap-4 text-charcoal/45 font-sans text-xs uppercase tracking-widest border-t border-cream-dark pt-4">
                <span>{listings[0].beds} bd</span><span>&middot;</span><span>{listings[0].baths} ba</span><span>&middot;</span><span>{listings[0].sqft} sf</span>
              </div>
            </div>
          </article>
        </div>

        <!-- Card 2: col-span-7 -->
        <div class="col-span-12 md:col-span-7 fade-in" style="transform: rotate(0.8deg);">
          <article class="listing-card bg-white overflow-hidden group cursor-pointer" style="box-shadow: 0 20px 60px rgba(0,0,0,0.15);">
            <div class="overflow-hidden" style="aspect-ratio: 4/3;">
              <img src={listings[1].image} alt={listings[1].address} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <p class="font-sans text-[10px] uppercase tracking-[0.2em] text-sage font-medium mb-1">{listings[1].neighborhood}</p>
                  <h3 class="font-serif font-bold text-charcoal text-xl">{listings[1].address}</h3>
                </div>
                <span class="px-3 py-1 bg-sage/10 text-sage text-[10px] font-sans font-medium uppercase tracking-widest rounded-full shrink-0 ml-3">{listings[1].status}</span>
              </div>
              <p class="font-serif font-black text-charcoal text-2xl mb-4">{listings[1].price}</p>
              <div class="flex gap-4 text-charcoal/45 font-sans text-xs uppercase tracking-widest border-t border-cream-dark pt-4">
                <span>{listings[1].beds} bd</span><span>&middot;</span><span>{listings[1].baths} ba</span><span>&middot;</span><span>{listings[1].sqft} sf</span>
              </div>
            </div>
          </article>
        </div>

        <!-- Row 2: 3x col-span-4 -->
        {listings.slice(2, 5).map((listing, i) => (
          <div class={`col-span-12 md:col-span-4 fade-in`} style={`transform: rotate(${i % 2 === 0 ? '0.8deg' : '-1.2deg'});`}>
            <article class="listing-card bg-white overflow-hidden group cursor-pointer" style="box-shadow: 0 20px 60px rgba(0,0,0,0.15);">
              <div class="overflow-hidden" style="aspect-ratio: 4/3;">
                <img src={listing.image} alt={listing.address} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
              </div>
              <div class="p-5">
                <div class="flex items-start justify-between mb-2">
                  <div>
                    <p class="font-sans text-[10px] uppercase tracking-[0.2em] text-sage font-medium mb-1">{listing.neighborhood}</p>
                    <h3 class="font-serif font-bold text-charcoal text-lg">{listing.address}</h3>
                  </div>
                  <span class="px-2 py-1 bg-sage/10 text-sage text-[10px] font-sans font-medium uppercase tracking-widest rounded-full shrink-0 ml-2">{listing.status}</span>
                </div>
                <p class="font-serif font-black text-charcoal text-xl mb-3">{listing.price}</p>
                <div class="flex gap-3 text-charcoal/45 font-sans text-xs uppercase tracking-widest border-t border-cream-dark pt-3">
                  <span>{listing.beds} bd</span><span>&middot;</span><span>{listing.baths} ba</span><span>&middot;</span><span>{listing.sqft} sf</span>
                </div>
              </div>
            </article>
          </div>
        ))}

        <!-- Row 3: col-span-7 + col-span-5 -->
        <div class="col-span-12 md:col-span-7 fade-in" style="transform: rotate(-0.8deg);">
          <article class="listing-card bg-white overflow-hidden group cursor-pointer" style="box-shadow: 0 20px 60px rgba(0,0,0,0.15);">
            <div class="overflow-hidden" style="aspect-ratio: 4/3;">
              <img src={listings[4].image} alt={listings[4].address} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <p class="font-sans text-[10px] uppercase tracking-[0.2em] text-sage font-medium mb-1">{listings[4].neighborhood}</p>
                  <h3 class="font-serif font-bold text-charcoal text-xl">{listings[4].address}</h3>
                </div>
                <span class="px-3 py-1 bg-sage/10 text-sage text-[10px] font-sans font-medium uppercase tracking-widest rounded-full shrink-0 ml-3">{listings[4].status}</span>
              </div>
              <p class="font-serif font-black text-charcoal text-2xl mb-4">{listings[4].price}</p>
              <div class="flex gap-4 text-charcoal/45 font-sans text-xs uppercase tracking-widest border-t border-cream-dark pt-4">
                <span>{listings[4].beds} bd</span><span>&middot;</span><span>{listings[4].baths} ba</span><span>&middot;</span><span>{listings[4].sqft} sf</span>
              </div>
            </div>
          </article>
        </div>

        <div class="col-span-12 md:col-span-5 fade-in" style="transform: rotate(1.2deg);">
          <article class="listing-card bg-white overflow-hidden group cursor-pointer" style="box-shadow: 0 20px 60px rgba(0,0,0,0.15);">
            <div class="overflow-hidden" style="aspect-ratio: 4/3;">
              <img src={listings[5].image} alt={listings[5].address} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <p class="font-sans text-[10px] uppercase tracking-[0.2em] text-sage font-medium mb-1">{listings[5].neighborhood}</p>
                  <h3 class="font-serif font-bold text-charcoal text-xl">{listings[5].address}</h3>
                </div>
                <span class="px-3 py-1 bg-sage/10 text-sage text-[10px] font-sans font-medium uppercase tracking-widest rounded-full shrink-0 ml-3">{listings[5].status}</span>
              </div>
              <p class="font-serif font-black text-charcoal text-2xl mb-4">{listings[5].price}</p>
              <div class="flex gap-4 text-charcoal/45 font-sans text-xs uppercase tracking-widest border-t border-cream-dark pt-4">
                <span>{listings[5].beds} bd</span><span>&middot;</span><span>{listings[5].baths} ba</span><span>&middot;</span><span>{listings[5].sqft} sf</span>
              </div>
            </div>
          </article>
        </div>
      </div>

      <div class="mt-16 text-center fade-in">
        <a href="#contact" class="inline-flex items-center gap-3 px-8 py-4 border-2 border-sage text-sage font-sans text-sm font-medium uppercase tracking-widest hover:bg-sage hover:text-cream transition-all duration-200 rounded-sm">
          View All Properties &rarr;
        </a>
      </div>
    </section>

    <!-- ===== CHAPTER TWO: LIFESTYLE VIGNETTES ===== -->
    <section id="lifestyle" class="py-24 lg:py-36 overflow-hidden">
      <div class="px-6 lg:px-16 mb-12 fade-in">
        <p class="text-[10px] font-sans font-medium uppercase tracking-[0.35em] text-sage mb-3">Chapter Two</p>
        <h2 class="font-serif font-black text-charcoal leading-tight" style="font-size: clamp(2.5rem, 5vw, 4.5rem);">Life at the<br /><em>Water's Edge</em></h2>
        <p class="mt-4 font-sans text-charcoal/55 max-w-lg leading-relaxed" style="font-size: 1.05rem;">
          Encinitas isn't just an address. It's a way of living — woven from salt air, golden afternoons, and community that feels like family.
        </p>
      </div>
      <!-- Horizontal scroll -->
      <div class="flex gap-5 overflow-x-auto pb-6 px-6 lg:px-16 snap-x snap-mandatory" style="-webkit-overflow-scrolling: touch; scrollbar-width: none; msOverflowStyle: none;">
        {lifestylePhotos.map((photo) => (
          <div class="shrink-0 relative snap-start group" style="width: clamp(280px, 38vw, 480px);">
            <div class="h-96 overflow-hidden rounded-sm">
              <img src={photo.src} alt={photo.caption} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
            <div class="absolute bottom-0 left-0 right-0 p-5 bg-gradient-to-t from-charcoal/75 via-charcoal/20 to-transparent rounded-b-sm">
              <p class="text-[9px] font-sans uppercase tracking-[0.3em] text-cream/65 mb-1">{photo.label}</p>
              <p class="font-serif italic text-cream text-xl">{photo.caption}</p>
              <p class="mt-2 text-cream/65 font-sans text-xs hover:text-cream transition-colors cursor-pointer">Learn more &rarr;</p>
            </div>
          </div>
        ))}
      </div>
    </section>

