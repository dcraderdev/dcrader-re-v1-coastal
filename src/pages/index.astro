  },
  {
    address: '1055 Via Vera Cruz',
    neighborhood: 'San Marcos',
    price: '$1.32M',
    soldDate: 'Oct 2024',
    image: 'https://images.unsplash.com/photo-1576941089067-2de3c901e126?w=600&q=70&fm=webp&fit=crop&auto=format',
  },
