    author: 'The Harrington Family',
    location: 'Leucadia, Encinitas',
  },
  {
    quote: "I've worked with a dozen agents over the years. Sarah is in a completely different league. Her market knowledge is encyclopedic, and she genuinely cares about finding the right fit.",
    author: 'Marcus & Diane Chen',
    location: 'Del Mar',
  },
  {
    quote: "She negotiated $180K below asking and still made the sellers feel good about the deal. That's a rare skill. Our family is forever grateful.",
    author: 'The Pemberton-Walsh Family',
    location: 'Solana Beach',
  },
];

const lifestylePhotos = [
  { src: 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=700&q=70&fm=webp', caption: 'Moonlight Beach', label: 'Encinitas' },
  { src: 'https://images.unsplash.com/photo-1519046904884-53103b34b206?w=700&q=70&fm=webp', caption: 'Morning Surf', label: 'Swamis Reef' },
  { src: 'https://images.unsplash.com/photo-1455587734955-081b22074882?w=700&q=70&fm=webp', caption: 'Golden Hour', label: 'Del Mar Bluffs' },
  { src: 'https://images.unsplash.com/photo-1473448912268-2022ce9509d8?w=700&q=70&fm=webp', caption: 'Family Memories', label: 'Cardiff State Beach' },
