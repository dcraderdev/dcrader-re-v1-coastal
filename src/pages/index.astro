  <script>
    // Mobile menu toggle
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobile-menu');
    const ham1 = document.getElementById('ham-1');
    const ham2 = document.getElementById('ham-2');
    const ham3 = document.getElementById('ham-3');
    let menuOpen = false;

    hamburger?.addEventListener('click', () => {
      menuOpen = !menuOpen;
      if (mobileMenu) {
        mobileMenu.style.transform = menuOpen ? 'translateX(0)' : 'translateX(100%)';
      }
      if (ham1 && ham2 && ham3) {
        if (menuOpen) {
          ham1.style.transform = 'rotate(45deg) translateY(6px)';
          ham2.style.opacity = '0';
          ham3.style.transform = 'rotate(-45deg) translateY(-6px)';
          ham3.style.width = '1.5rem';
        } else {
          ham1.style.transform = '';
          ham2.style.opacity = '1';
          ham3.style.transform = '';
          ham3.style.width = '1rem';
        }
      }
    });

    // Close mobile menu on nav link click
    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => {
        menuOpen = false;
        if (mobileMenu) mobileMenu.style.transform = 'translateX(100%)';
        if (ham1 && ham2 && ham3) {
          ham1.style.transform = '';
          ham2.style.opacity = '1';
          ham3.style.transform = '';
          ham3.style.width = '1rem';
        }
      });
    });

    // Floating CTA pill — appears after scrolling past hero
    const floatingCta = document.getElementById('floating-cta');
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY > window.innerHeight * 0.7;
      if (floatingCta) {
        floatingCta.style.opacity = scrolled ? '1' : '0';
        floatingCta.style.transform = scrolled ? 'translateY(0)' : 'translateY(1rem)';
      }
    });

    // Scroll-triggered fade-in via IntersectionObserver
    const fadeEls = document.querySelectorAll('.fade-in');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).style.opacity = '1';
            (entry.target as HTMLElement).style.transform =
              (entry.target as HTMLElement).style.transform.replace('translateY(2rem)', 'translateY(0)') || 'translateY(0)';
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
    );

    fadeEls.forEach((el) => {
      const htmlEl = el as HTMLElement;
      // Preserve any existing rotation transform
      const existingTransform = htmlEl.style.transform;
      htmlEl.style.opacity = '0';
      htmlEl.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      if (!existingTransform || existingTransform === '') {
        htmlEl.style.transform = 'translateY(2rem)';
      }
      observer.observe(el);
    });

    // Listing card hover — preserve rotation context
    document.querySelectorAll('.listing-card').forEach((card) => {
      const parent = card.parentElement as HTMLElement;
      const baseRotation = parent?.style.transform || '';

      card.addEventListener('mouseenter', () => {
        if (parent) {
          parent.style.transform = 'rotate(0deg) translateY(-6px)';
          parent.style.zIndex = '10';
        }
        (card as HTMLElement).style.boxShadow = '0 30px 80px rgba(0,0,0,0.22)';
      });
      card.addEventListener('mouseleave', () => {
        if (parent) {
          parent.style.transform = baseRotation;
          parent.style.zIndex = '';
        }
        (card as HTMLElement).style.boxShadow = '0 20px 60px rgba(0,0,0,0.15)';
      });
    });

    // Contact form submission (demo)
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const formSuccess = document.getElementById('form-success');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      if (form && formSuccess) {
        form.style.display = 'none';
        formSuccess.classList.remove('hidden');
      }
    });
  </script>
